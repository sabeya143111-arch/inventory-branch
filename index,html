}

/* ===================== DATA ===================== */
let DATA=[], state={branch:null, cat:'الكل', q:''};

function mapItem(it){
  const branch = (it[BRANCH_KEY]||'غير محدد').toString().trim();
  const brand = (branch.split(/[-–]/)[0]||'').trim() || '—';
  let photo='';
  try{ const p=JSON.parse(it.DevicePhoto); if(p&&p.serverRelativeUrl) photo=(p.serverUrl||ORIGIN)+p.serverRelativeUrl; }catch(_){}
  const qn = parseInt(String(it.SerialNumber).replace(/[^\d]/g,''),10);
  return {
    id: it.ID, branch, brand,
    name: it.Title || '—',
    category: it.AssetType || 'أخرى',
    model: it.Model || '',
    status: it.Status || '',
    color: it.Color || '',
    qty: Number.isFinite(qn) && qn>0 ? qn : 1,
    notes: it.ConditionNotes || '',
    purchaseDate: it.PurchaseDate || '',
    amount: Number(it.PurchasePrice)||0,
    invoice: it.OrderNumber || '',
    photo,
    created: it.Created || ''
  };
}

async function loadData(refresh){
  if(!await getToken()) return;
  const host=document.getElementById('page-'+currentTab);
  if(refresh) toast('جارٍ التحديث…','');
  try{
    const url=`${SITE}/_api/web/lists(guid'${LIST}')/items?$top=2000&$orderby=ID desc`;
    const r=await fetch(url,{headers:{'Accept':'application/json;odata=nometadata','Authorization':`Bearer ${accessToken}`}});
    if(!r.ok){ const t=await r.text(); throw new Error('HTTP '+r.status+(r.status===403?' — صلاحية القراءة (AllSites.Read) غير ممنوحة':'')); }
    const j=await r.json(); const raw=j.value||[];
    // auto-detect branch key (encoded Arabic name) once
    if(raw[0]){ const k=Object.keys(raw[0]).find(k=>k.startsWith('OData__x0627__x0644__x0641__x0631')); if(k) BRANCH_KEY=k; }
    DATA=raw.map(mapItem);
    if(refresh) toast(`تم تحميل ${DATA.length} قطعة`,'success');
    render();
  }catch(e){ toast('فشل التحميل: '+e.message,'error'); console.error(e); }
}

/* ===================== AGGREGATES ===================== */
function branchAgg(){
  const m={};
  DATA.forEach(d=>{ (m[d.branch]??=({brand:d.brand,types:0,units:0,value:0,cats:{},last:d.created}));
    const b=m[d.branch]; b.types++; b.units+=d.qty; b.value+=d.amount*d.qty; b.cats[d.category]=(b.cats[d.category]||0)+1; });
  return m;
}
function barcode(seed){ let h=0; for(const c of String(seed)) h=(h*33+c.charCodeAt(0))>>>0; let s=''; for(let i=0;i<32;i++){ h=(h*1103515245+12345)>>>0; s+=`<i style="flex:${1+(h%4)}"></i>`; } return `<div class="barcode">${s}</div>`; }

/* ===================== COUNTERS ===================== */
function animate(el,to){ const dur=700,st=performance.now(),from=0; function f(t){ const p=Math.min(1,(t-st)/dur); el.textContent=fmt(Math.round(from+(to-from)*(1-Math.pow(1-p,3)))); if(p<1)requestAnimationFrame(f); } requestAnimationFrame(f); }


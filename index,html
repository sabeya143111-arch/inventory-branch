const CAT_COLOR={'كمبيوتر':'#3fb9c4','أخرى':'#8a97a8','كراسي':'#d4a84b','أثاث':'#b07a3a','شبكات':'#60a5fa','كاميرات':'#f87171'};
const COLOR_HEX={'أسود':'#1c1c1e','رمادي':'#8a8f98','أبيض':'#f3f4f6','فضي':'#cfd4d9','بني':'#6b4a2b','ذهبي':'#c9a227','أزرق':'#2f6fed','أحمر':'#d6473e','أخضر':'#1f9e6a'};
function catColor(c){ if(CAT_COLOR[c])return CAT_COLOR[c]; let h=0; for(const ch of (c||'')) h=(h*31+ch.charCodeAt(0))%360; return `hsl(${h} 55% 55%)`; }
function brandColor(b){ return BRAND_COLOR[b]||'#3fb9c4'; }
function colorHex(c){ return COLOR_HEX[c]||'#5a6b7c'; }
function statusClass(s){ s=s||''; if(s.includes('متوقف')||s.includes('تالف'))return'st-stop'; if(s.includes('صيان'))return'st-fix'; if(s.includes('مخزن')||s.includes('احتياط'))return'st-store'; if(s.includes('استخدام'))return'st-use'; return s?'st-x':'st-x'; }
const fmt=n=>new Intl.NumberFormat('en-US').format(n||0);
const fmtMoney=n=>n?fmt(n)+' ر.س':'—';
function fmtDate(d){ if(!d)return'—'; try{return new Date(d).toLocaleDateString('ar-SA',{day:'numeric',month:'short',year:'numeric'});}catch(_){return d;} }
const esc=s=>String(s??'').replace(/[&<>"]/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[c]));

function icon(cat,name){
  const n=(name||'')+(cat||'');
  if(n.includes('كاشير')||n.includes('كمبيوتر')||n.includes('cpu')) return '<path d="M3 5h18v11H3z"/><path d="M8 21h8M12 16v5"/>';
  if(n.includes('لابتوب')) return '<path d="M4 5h16v10H4z"/><path d="M2 19h20l-2-2H4z"/>';
  if(n.includes('شاشة')) return '<path d="M3 4h18v12H3z"/><path d="M9 20h6M12 16v4"/>';
  if(n.includes('طابعة')) return '<path d="M6 9V3h12v6"/><path d="M6 18H4a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v3a2 2 0 0 1-2 2h-2"/><path d="M6 14h12v7H6z"/>';
  if(n.includes('جرد')||n.includes('سكانر')||n.includes('باركود')) return '<path d="M3 5v14M7 5v14M11 5v14M15 5v14M19 5v14"/>';
  if(n.includes('كرسي')) return '<path d="M6 18v-6a3 3 0 0 1 3-3h6a3 3 0 0 1 3 3v6"/><path d="M6 18v3M18 18v3M4 12h16"/>';
  if(n.includes('كاميرا')) return '<path d="M2 7h13l3 3v7H2z"/><circle cx="9" cy="13" r="3"/><path d="M18 9l4-2v9l-4-2"/>';
  if(n.includes('طاولة')||n.includes('رف')||n.includes('أثاث')) return '<path d="M3 7h18M5 7v13M19 7v13M3 13h18"/>';

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>جرد الأدوات والموارد — الفروع</title>
<script src="https://cdn.jsdelivr.net/npm/@azure/msal-browser@3.4.0/lib/msal-browser.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=Tajawal:wght@400;500;700&family=IBM+Plex+Mono:wght@500;600&display=swap" rel="stylesheet">
<style>
  :root{
    --bg:#0a0e16; --bg2:#0f1623; --card:#121a29; --card2:#161f31; --line:rgba(255,255,255,.08);
    --text:#e7edf5; --muted:#8a97a8; --muted2:#aab6c6;
    --accent:#3fb9c4; --accent2:#7c5cff; --gold:#d4a84b;
    --green:#34d399; --red:#f87171; --amber:#fbbf24; --blue:#60a5fa;
    --shadow:0 10px 30px rgba(0,0,0,.35);
    --r:16px;
  }
  :root[data-theme="light"]{
    --bg:#eef2f7; --bg2:#e6ecf3; --card:#ffffff; --card2:#f7f9fc; --line:rgba(20,40,60,.1);
    --text:#16222e; --muted:#6b7888; --muted2:#41505f; --shadow:0 10px 30px rgba(20,40,60,.1);
  }
  *{box-sizing:border-box}
  html,body{margin:0;padding:0}
  body{font-family:'Tajawal',system-ui,sans-serif;background:
    radial-gradient(900px 500px at 100% -10%, rgba(63,185,196,.12), transparent 55%),
    radial-gradient(900px 500px at -10% 110%, rgba(124,92,255,.12), transparent 55%),
    var(--bg); color:var(--text); min-height:100vh; -webkit-font-smoothing:antialiased; transition:background .3s}
  .gr{font-family:'Space Grotesk',sans-serif}
  .mono{font-family:'IBM Plex Mono',monospace;font-feature-settings:"tnum"}
  button{font-family:inherit}

  /* ===== LOGIN ===== */
  #login{position:fixed;inset:0;display:grid;place-items:center;padding:20px;z-index:50}
  .login-card{background:var(--card);border:1px solid var(--line);border-radius:24px;padding:40px 36px;max-width:400px;width:100%;text-align:center;box-shadow:var(--shadow)}
  .logo{width:64px;height:64px;border-radius:18px;margin:0 auto 18px;background:linear-gradient(135deg,var(--accent),var(--accent2));display:grid;place-items:center;box-shadow:0 12px 30px rgba(63,185,196,.4)}
  .logo svg{width:34px;height:34px;stroke:#fff;fill:none;stroke-width:1.8}
  .login-card h1{font-family:'Space Grotesk';font-size:22px;margin:0 0 6px}
  .login-card p{color:var(--muted);font-size:14px;margin:0 0 26px}
  .ms-btn{display:inline-flex;align-items:center;gap:11px;background:#fff;color:#1b1b1b;border:0;border-radius:12px;padding:13px 22px;font-size:15px;font-weight:700;cursor:pointer;transition:transform .15s,box-shadow .15s;box-shadow:0 6px 18px rgba(0,0,0,.25)}
  .ms-btn:hover{transform:translateY(-2px);box-shadow:0 10px 26px rgba(0,0,0,.35)}
  .ms-btn .ms-logo{width:18px;height:18px;display:grid;grid-template-columns:1fr 1fr;gap:2px}
  .ms-logo i{display:block}.ms-logo i:nth-child(1){background:#f25022}.ms-logo i:nth-child(2){background:#7fba00}.ms-logo i:nth-child(3){background:#00a4ef}.ms-logo i:nth-child(4){background:#ffb900}

  /* ===== APP SHELL ===== */
  #app{display:none}
  header{position:sticky;top:0;z-index:30;background:rgba(10,14,22,.82);backdrop-filter:blur(14px);border-bottom:1px solid var(--line)}
  :root[data-theme="light"] header{background:rgba(238,242,247,.85)}
  .topbar{display:flex;align-items:center;gap:16px;padding:12px clamp(14px,3vw,32px);flex-wrap:wrap}
  .brand{display:flex;align-items:center;gap:11px}
  .brand .logo{width:40px;height:40px;border-radius:11px;margin:0;box-shadow:0 6px 16px rgba(63,185,196,.35)}
  .brand .logo svg{width:22px;height:22px}
  .brand h1{font-family:'Space Grotesk';font-size:16px;margin:0}
  .brand .sub{font-size:11.5px;color:var(--muted)}
  .nav{display:flex;gap:4px;margin-inline-start:8px;flex-wrap:wrap}
  .nav button{background:transparent;border:0;color:var(--muted);font-weight:500;font-size:14px;padding:9px 15px;border-radius:10px;cursor:pointer;transition:.15s;display:flex;align-items:center;gap:7px}
  .nav button svg{width:16px;height:16px;stroke:currentColor;fill:none;stroke-width:1.9}
  .nav button:hover{color:var(--text);background:var(--card)}
  .nav button.active{color:var(--text);background:linear-gradient(135deg,rgba(63,185,196,.2),rgba(124,92,255,.2));box-shadow:inset 0 0 0 1px var(--line)}
  .spacer{margin-inline-start:auto}
  .icobtn{background:var(--card);border:1px solid var(--line);color:var(--muted2);width:38px;height:38px;border-radius:10px;cursor:pointer;display:grid;place-items:center;transition:.15s}
  .icobtn:hover{color:var(--text);border-color:var(--accent)}
  .icobtn svg{width:17px;height:17px;stroke:currentColor;fill:none;stroke-width:1.9}
  .user{display:flex;align-items:center;gap:9px;background:var(--card);border:1px solid var(--line);border-radius:10px;padding:6px 12px;font-size:13px}
  .user .av{width:26px;height:26px;border-radius:50%;background:linear-gradient(135deg,var(--accent),var(--accent2));display:grid;place-items:center;font-weight:700;font-size:12px;color:#fff}
  .user .nm{max-width:120px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}

  main{padding:clamp(16px,3vw,30px) clamp(14px,3vw,32px) 60px;max-width:1320px;margin:0 auto}
  .page{display:none}.page.active{display:block;animation:fade .35s ease both}
  @keyframes fade{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:none}}

  .head{display:flex;align-items:flex-end;justify-content:space-between;gap:14px;flex-wrap:wrap;margin-bottom:20px}
  .eyebrow{font-family:'IBM Plex Mono';font-size:11px;letter-spacing:2px;color:var(--accent);text-transform:uppercase}
  .head h2{font-family:'Space Grotesk';font-size:24px;margin:5px 0 0}
  .search{position:relative;min-width:min(320px,70vw)}
  .search input{width:100%;background:var(--card);border:1px solid var(--line);color:var(--text);border-radius:11px;padding:11px 40px 11px 14px;font-family:'Tajawal';font-size:14px;outline:none;transition:.15s}
  .search input:focus{border-color:var(--accent);box-shadow:0 0 0 3px rgba(63,185,196,.2)}
  .search svg{position:absolute;inset-inline-end:13px;top:50%;transform:translateY(-50%);width:17px;height:17px;stroke:var(--muted);fill:none;stroke-width:2}

  /* counters */
  .stats{display:grid;gap:14px;grid-template-columns:repeat(auto-fit,minmax(170px,1fr));margin-bottom:24px}
  .stat{background:var(--card);border:1px solid var(--line);border-radius:var(--r);padding:18px 20px;position:relative;overflow:hidden}
  .stat::after{content:"";position:absolute;inset-inline-end:-20px;top:-20px;width:80px;height:80px;border-radius:50%;background:radial-gradient(circle,var(--c,var(--accent)),transparent 70%);opacity:.18}
  .stat .lab{font-size:13px;color:var(--muted);display:flex;align-items:center;gap:7px}
  .stat .lab svg{width:15px;height:15px;stroke:var(--c,var(--accent));fill:none;stroke-width:2}
  .stat .num{font-family:'IBM Plex Mono';font-weight:600;font-size:30px;margin-top:8px}
  .stat .unit{font-size:13px;color:var(--muted);font-family:'Tajawal'}

  /* branch tags */
  .grid{display:grid;gap:16px;grid-template-columns:repeat(auto-fill,minmax(255px,1fr))}
  .tag{position:relative;background:linear-gradient(160deg,var(--card),var(--card2));border:1px solid var(--line);border-radius:var(--r);padding:18px 20px 16px;cursor:pointer;text-align:start;color:var(--text);overflow:hidden;transition:transform .16s,box-shadow .16s,border-color .16s}
  .tag:hover{transform:translateY(-4px);box-shadow:var(--shadow);border-color:rgba(63,185,196,.4)}
  .tag:focus-visible{outline:3px solid rgba(63,185,196,.5);outline-offset:2px}
  .badge{font-family:'Space Grotesk';font-weight:700;font-size:11px;color:#fff;padding:3px 11px;border-radius:999px;white-space:nowrap}
  .tag h3{font-family:'Space Grotesk';font-size:18px;margin:13px 0 2px}
  .qstamp{position:absolute;top:16px;inset-inline-end:18px;text-align:center}
  .qstamp b{font-family:'IBM Plex Mono';font-weight:600;font-size:26px;display:block;line-height:1;color:var(--accent)}
  .qstamp span{font-size:10px;color:var(--muted)}
  .barcode{display:flex;gap:2px;height:24px;margin:14px 0 12px;opacity:.5}
  .barcode i{display:block;background:var(--text);border-radius:1px}
  .tagfoot{display:flex;align-items:center;justify-content:space-between;gap:8px;border-top:1px dashed var(--line);padding-top:11px}
  .chips{display:flex;gap:5px;flex-wrap:wrap}
  .chip{font-size:11px;background:var(--card2);border:1px solid var(--line);color:var(--muted2);padding:3px 9px;border-radius:7px}
  .types{font-family:'IBM Plex Mono';font-size:12px;color:var(--muted)}.types b{color:var(--text)}

  /* branch detail */
  .back{display:inline-flex;align-items:center;gap:7px;background:var(--card);border:1px solid var(--line);color:var(--muted2);font-size:13px;font-weight:500;padding:8px 13px;border-radius:10px;cursor:pointer;margin-bottom:16px;transition:.15s}
  .back:hover{border-color:var(--accent);color:var(--text)}
  .back svg{width:15px;height:15px;stroke:currentColor;fill:none;stroke-width:2;transform:scaleX(-1)}
  .bhead{background:linear-gradient(160deg,var(--card),var(--card2));border:1px solid var(--line);border-radius:var(--r);padding:20px 22px;margin-bottom:18px;display:flex;gap:18px;flex-wrap:wrap;align-items:flex-start}
  .bhead .l{flex:1;min-width:200px}.bhead h2{font-family:'Space Grotesk';font-size:23px;margin:8px 0 3px}
  .ministats{display:flex;gap:22px;flex-wrap:wrap;margin-inline-start:auto}
  .ms{text-align:center}.ms b{font-family:'IBM Plex Mono';font-weight:600;font-size:22px;color:var(--accent);display:block}.ms span{font-size:11px;color:var(--muted)}
  .pills{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:18px}
  .pill{background:var(--card);border:1px solid var(--line);color:var(--muted2);font-size:13px;font-weight:500;padding:7px 14px;border-radius:999px;cursor:pointer;transition:.15s}
  .pill:hover{border-color:var(--accent)}.pill.active{background:var(--accent);border-color:var(--accent);color:#04222a}
  .pill .n{font-family:'IBM Plex Mono';opacity:.6;margin-inline-start:5px;font-size:12px}
  .catsec{margin-bottom:24px}
  .catbar{display:flex;align-items:center;gap:10px;margin-bottom:12px}
  .catdot{width:11px;height:11px;border-radius:3px;flex:none}
  .catbar h4{font-family:'Space Grotesk';font-size:15px;margin:0}
  .catbar .meta{font-family:'IBM Plex Mono';font-size:12px;color:var(--muted);margin-inline-start:auto}
  .cards{display:grid;gap:13px;grid-template-columns:repeat(auto-fill,minmax(230px,1fr))}
  .asset{background:var(--card);border:1px solid var(--line);border-radius:13px;overflow:hidden;cursor:pointer;text-align:start;color:var(--text);padding:0;transition:transform .15s,box-shadow .15s,border-color .15s}
  .asset:hover{transform:translateY(-3px);box-shadow:var(--shadow);border-color:rgba(63,185,196,.4)}
  .asset:focus-visible{outline:3px solid rgba(63,185,196,.5);outline-offset:2px}
  .thumb{height:120px;background:linear-gradient(135deg,var(--card2),var(--bg2));display:grid;place-items:center;position:relative;background-size:cover;background-position:center}
  .thumb svg{width:46px;height:46px;stroke:var(--muted);fill:none;stroke-width:1.4}
  .qpill{position:absolute;top:9px;inset-inline-start:9px;background:rgba(0,0,0,.6);color:#fff;font-family:'IBM Plex Mono';font-size:12px;font-weight:600;padding:3px 9px;border-radius:8px;backdrop-filter:blur(4px)}
  .abody{padding:12px 14px 14px}.abody h5{font-family:'Space Grotesk';font-size:15px;margin:0 0 3px}
  .model{font-family:'IBM Plex Mono';font-size:12px;color:var(--muted);margin-bottom:10px;word-break:break-all;min-height:15px}
  .row{display:flex;align-items:center;gap:8px;flex-wrap:wrap}
  .swatch{width:13px;height:13px;border-radius:50%;border:1px solid rgba(255,255,255,.25);flex:none}
  .clr{font-size:12px;color:var(--muted2)}
  .status{font-size:11px;font-weight:700;padding:3px 10px;border-radius:999px;margin-inline-start:auto}
  .st-use{background:rgba(52,211,153,.15);color:var(--green)}.st-stop{background:rgba(248,113,113,.15);color:var(--red)}
  .st-fix{background:rgba(251,191,36,.15);color:var(--amber)}.st-store{background:rgba(96,165,250,.15);color:var(--blue)}.st-x{background:var(--card2);color:var(--muted2)}

  /* table */
  .tablewrap{background:var(--card);border:1px solid var(--line);border-radius:var(--r);overflow:auto}
  table{width:100%;border-collapse:collapse;min-width:760px}
  th,td{padding:12px 14px;text-align:start;font-size:13.5px;border-bottom:1px solid var(--line);white-space:nowrap}
  th{font-family:'Space Grotesk';font-size:12px;color:var(--muted);font-weight:600;position:sticky;top:0;background:var(--card)}
  tbody tr{cursor:pointer;transition:.12s}tbody tr:hover{background:var(--card2)}
  .idtag{font-family:'IBM Plex Mono';font-size:12px;color:var(--accent);background:rgba(63,185,196,.1);padding:2px 8px;border-radius:6px}

  /* charts */
  .chartgrid{display:grid;gap:16px;grid-template-columns:repeat(auto-fit,minmax(300px,1fr))}
  .chartcard{background:var(--card);border:1px solid var(--line);border-radius:var(--r);padding:18px 20px}
  .chartcard h4{font-family:'Space Grotesk';font-size:15px;margin:0 0 14px}
  .chartcard .cwrap{height:260px;position:relative}

  /* modal */
  .ov{position:fixed;inset:0;background:rgba(4,8,14,.7);backdrop-filter:blur(4px);display:none;place-items:center;z-index:60;padding:18px}
  .ov.open{display:grid}
  .modal{background:var(--card);border:1px solid var(--line);border-radius:18px;max-width:460px;width:100%;overflow:hidden;box-shadow:var(--shadow);animation:pop .2s ease}
  @keyframes pop{from{transform:translateY(12px) scale(.98);opacity:0}to{transform:none;opacity:1}}
  .mthumb{height:170px;background:linear-gradient(135deg,var(--card2),var(--bg2));display:grid;place-items:center;position:relative;background-size:cover;background-position:center}
  .mthumb svg{width:60px;height:60px;stroke:var(--muted);fill:none;stroke-width:1.3}
  .mclose{position:absolute;top:12px;inset-inline-end:12px;width:32px;height:32px;border:0;border-radius:9px;background:rgba(0,0,0,.5);cursor:pointer;display:grid;place-items:center}
  .mclose svg{width:17px;height:17px;stroke:#fff;stroke-width:2.2;fill:none}
  .mbody{padding:18px 22px 22px}.mbody h3{font-family:'Space Grotesk';font-size:21px;margin:0 0 2px}
  .mbody .model{font-size:13px;margin-bottom:14px}
  .kv{display:grid;grid-template-columns:auto 1fr;gap:10px 16px;font-size:14px}
  .kv dt{color:var(--muted)}.kv dd{margin:0;font-weight:500}.kv dd.mono{font-family:'IBM Plex Mono';font-weight:600}

  .empty{text-align:center;padding:70px 20px;color:var(--muted)}
  .empty svg{width:46px;height:46px;stroke:var(--line);fill:none;stroke-width:1.4;margin-bottom:12px}
  .spin{width:42px;height:42px;border:3px solid var(--line);border-top-color:var(--accent);border-radius:50%;animation:sp 1s linear infinite;margin:60px auto}
  @keyframes sp{to{transform:rotate(360deg)}}

  /* toast */
  #toasts{position:fixed;bottom:20px;inset-inline-start:20px;z-index:80;display:flex;flex-direction:column;gap:10px}
  .toast{background:var(--card);border:1px solid var(--line);border-inline-start:3px solid var(--accent);border-radius:11px;padding:12px 16px;font-size:14px;box-shadow:var(--shadow);animation:slide .25s ease;max-width:340px}
  .toast.error{border-inline-start-color:var(--red)}.toast.success{border-inline-start-color:var(--green)}
  @keyframes slide{from{transform:translateX(-20px);opacity:0}to{transform:none;opacity:1}}

  @media (prefers-reduced-motion:reduce){*{animation:none!important;transition:none!important}}
</style>
</head>
<body>

<!-- LOGIN -->
<div id="login">
  <div class="login-card">
    <div class="logo"><svg viewBox="0 0 24 24"><path d="M3 9l9-6 9 6v10a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><path d="M9 21V12h6v9"/></svg></div>
    <h1 class="gr">جرد الأدوات والموارد</h1>
    <p>سجّل الدخول بحساب Microsoft لعرض أصول الفروع</p>
    <button class="ms-btn" onclick="signIn()">
      <span class="ms-logo"><i></i><i></i><i></i><i></i></span>
      تسجيل الدخول عبر Microsoft
    </button>
  </div>
</div>

<!-- APP -->
<div id="app">
  <header>
    <div class="topbar">
      <div class="brand">
        <div class="logo"><svg viewBox="0 0 24 24"><path d="M3 9l9-6 9 6v10a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><path d="M9 21V12h6v9"/></svg></div>
        <div><h1 class="gr">جرد الأدوات</h1><div class="sub">أصول الفروع</div></div>
      </div>
      <nav class="nav" id="nav">
        <button data-tab="overview" class="active" onclick="switchTab('overview')"><svg viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="9"/><rect x="14" y="3" width="7" height="5"/><rect x="14" y="12" width="7" height="9"/><rect x="3" y="16" width="7" height="5"/></svg>نظرة عامة</button>
        <button data-tab="branches" onclick="switchTab('branches')"><svg viewBox="0 0 24 24"><path d="M3 21h18M5 21V7l8-4v18M19 21V11l-6-4"/></svg>الفروع</button>
        <button data-tab="all" onclick="switchTab('all')"><svg viewBox="0 0 24 24"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>كل الأصول</button>
        <button data-tab="analytics" onclick="switchTab('analytics')"><svg viewBox="0 0 24 24"><path d="M3 3v18h18"/><path d="M7 14l4-4 3 3 5-6"/></svg>التحليلات</button>
      </nav>
      <div class="spacer"></div>
      <button class="icobtn" onclick="loadData(true)" title="تحديث"><svg viewBox="0 0 24 24"><path d="M21 12a9 9 0 1 1-3-6.7L21 8"/><path d="M21 3v5h-5"/></svg></button>
      <button class="icobtn" onclick="toggleTheme()" title="الوضع"><svg viewBox="0 0 24 24"><path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"/></svg></button>
      <div class="user"><div class="av" id="av">?</div><span class="nm" id="uname">…</span></div>
      <button class="icobtn" onclick="signOut()" title="خروج"><svg viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><path d="M16 17l5-5-5-5M21 12H9"/></svg></button>
    </div>
  </header>

  <main>
    <div class="page active" id="page-overview"></div>
    <div class="page" id="page-branches"></div>
    <div class="page" id="page-all"></div>
    <div class="page" id="page-analytics"></div>
  </main>
</div>

<div class="ov" id="ov" role="dialog" aria-modal="true"><div class="modal" id="modal"></div></div>
<div id="toasts"></div>

<script>
/* ===================== CONFIG (real list) ===================== */
const SITE   = 'https://netorg20570594.sharepoint.com/sites/-484';
const ORIGIN = 'https://netorg20570594.sharepoint.com';
const LIST   = 'bbd080c2-22dc-4cd1-a543-3a0cb6b629f1';            // المواد الزيادة بالفروع
const CLIENT = 'b459fb3f-d16d-484b-aa16-1e26dc9f2129';            // SwagLock app
const TENANT = 'fa3cca65-daac-4f03-8efd-c9c233c8c1d7';
const SCOPES = ['https://netorg20570594.sharepoint.com/AllSites.Read', 'User.Read'];
// branch field internal name (الفرع) — auto-detected from data, this is the fallback
let BRANCH_KEY = 'OData__x0627__x0644__x0641__x0631__x0639_';

/* ===================== MSAL ===================== */
const msalInstance = new msal.PublicClientApplication({
  auth:{ clientId:CLIENT, authority:`https://login.microsoftonline.com/${TENANT}`, redirectUri: window.location.origin + window.location.pathname },
  cache:{ cacheLocation:'localStorage' }
});
let accessToken=null, currentUser=null;

function signIn(){ msalInstance.loginRedirect({ scopes:SCOPES }); }
function signOut(){ msalInstance.logoutRedirect(); }
async function getToken(){
  const acc = msalInstance.getAllAccounts()[0]; if(!acc) return false;
  try{ const r = await msalInstance.acquireTokenSilent({ scopes:SCOPES, account:acc }); accessToken=r.accessToken; return true; }
  catch(e){ await msalInstance.acquireTokenRedirect({ scopes:SCOPES }); return false; }
}
function setUser(acc){

  const ws=XLSX.utils.json_to_sheet(rows); const wb=XLSX.utils.book_new(); XLSX.utils.book_append_sheet(wb,ws,'الأصول'); XLSX.writeFile(wb,'جرد_الأصول.xlsx');
}
function toggleTheme(){ const r=document.documentElement; const cur=r.getAttribute('data-theme'); r.setAttribute('data-theme',cur==='light'?'dark':'light'); if(currentTab==='analytics')renderAnalytics(); }

